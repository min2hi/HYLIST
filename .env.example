# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me-to-a-32-char-random-string-in-production
LOG_LEVEL=INFO

# ─── Database (PostgreSQL 17) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://hylist:secret@localhost:5432/hylist_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ─── Cache / Queue (Redis 7) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth (JWT) ───────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── ML / MLflow (Phase 2 — bỏ comment khi đến tuần 5) ───────────────────────
MLFLOW_TRACKING_URI=http://localhost:5001
ONNX_MODEL_PATH=ml/models/predictor_latest.onnx
DRIFT_THRESHOLD_MAE=2.0
SHADOW_MODE_ENABLED=true

# ─── LLM / Agent (Phase 4 — bỏ comment khi đến tuần 13) ──────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_DAILY_BUDGET_USD=10.0
HITL_CONFIDENCE_THRESHOLD=0.95

# ─── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
PROMETHEUS_PORT=9090

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
