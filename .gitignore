# ML model binaries (track via DVC, not git)
ml/models/*.pkl
ml/models/*.onnx
ml/models/*.ubj
ml/models/mlflow.db

# MLflow tracking data (generated at runtime, too large for git)
mlruns/
ml/mlruns/

# DVC-managed data files — track via .dvc files, not raw data
ml/data/*.csv
ml/data/*.json
!ml/data/.gitkeep
!ml/data/.gitignore

# Temporary one-off scripts (should never be committed)
_*.py
